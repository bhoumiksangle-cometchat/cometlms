# =============================================================================
# CometLMS — Root Environment Variables
# 1. cp .env.example .env
# 2. Fill in every value marked CHANGE_ME
# 3. docker compose up -d --build
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_DB=cometlms
POSTGRES_USER=cometlms
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ---------------------------------------------------------------------------
# JWT  —  generate with:  openssl rand -base64 48
# ---------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_jwt_secret
JWT_REFRESH_SECRET=CHANGE_ME_jwt_refresh_secret

# ---------------------------------------------------------------------------
# AI  —  Groq
# ---------------------------------------------------------------------------
GROQ_API_KEY=gsk_CHANGE_ME
GROQ_MODEL=llama-3.3-70b-versatile

# ---------------------------------------------------------------------------
# URLs
# WEB domain  →  where the React app is served  (lms.cometchat-staging.com)
# API domain  →  where Express is reachable     (cometlms-a.cometchat-staging.com)
#
# CLIENT_URL / WEB_URL / FRONTEND_URL  are used by the API for CORS.
# Set them to the public domain(s) that browsers will use.
# ---------------------------------------------------------------------------
CLIENT_URL=https://lms.cometchat-staging.com
WEB_URL=https://lms.cometchat-staging.com
FRONTEND_URL=https://lms.cometchat-staging.com

# ---------------------------------------------------------------------------
# Vite build-time variable (baked into the React bundle at docker build time)
# Leave EMPTY — Nginx proxies /api → api:3000 inside the Docker network.
# Only set this if the web app is served from a DIFFERENT host than the API.
# ---------------------------------------------------------------------------
VITE_API_URL=

# ---------------------------------------------------------------------------
# Web container host port
# If port 80 is already taken on the EC2 host, change this to e.g. 8080.
# The internal Nginx always listens on 80; only the HOST mapping changes.
# ---------------------------------------------------------------------------
WEB_PORT=80

# ---------------------------------------------------------------------------
# Firebase Admin SDK  (push notifications — optional, leave blank to disable)
# Download the service-account JSON from Firebase Console → Project Settings
# ---------------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ---------------------------------------------------------------------------
# Firebase Web SDK  (baked into the React bundle — optional)
# ---------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# ---------------------------------------------------------------------------
# Sentry  (optional)
# ---------------------------------------------------------------------------
SENTRY_DSN=
