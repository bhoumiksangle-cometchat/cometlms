# =============================================================================
# CometchaT — Environment Variables
# Copy to .env.cometchat and fill in your values before deploying
# Deploy with: docker compose -f docker-compose.cometchat.yml --env-file .env.cometchat up -d --build
# =============================================================================

# --- PostgreSQL (CometchaT Database) ---
POSTGRES_DB=cometchat
POSTGRES_USER=cometchat
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# --- JWT (generate with: openssl rand -base64 48) ---
JWT_SECRET=CHANGE_ME_jwt_secret
JWT_REFRESH_SECRET=CHANGE_ME_jwt_refresh_secret

# --- AI (Groq) ---
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Frontend URL (set to your server IP or domain with port 8081) ---
# Used by the API for CORS allow-origin
CLIENT_URL=http://YOUR_SERVER_IP:8081
WEB_URL=http://YOUR_SERVER_IP:8081
FRONTEND_URL=http://YOUR_SERVER_IP:8081

# --- Vite build-time variable ---
# The frontend calls this URL for API requests.
# Since Nginx proxies /api → api:3001, this should be relative or absolute to the public host.
# Use empty string or /api for the Nginx proxy path (recommended).
VITE_API_URL=

# --- Sentry (optional) ---
SENTRY_DSN=
