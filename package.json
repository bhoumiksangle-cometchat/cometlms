{
  "name": "lms-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Learning Management System - Full Stack Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "build:api": "npm run build -w apps/api",
    "build:web": "npm run build -w apps/web",
    "build:shared-types": "npm run build -w packages/shared-types",
    "build:shared-utils": "npm run build -w packages/shared-utils",
    "build": "npm run build:shared-types && npm run build:shared-utils && npm run build:api && npm run build:web",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "lint": "eslint apps/*/src --ext .ts,.tsx",
    "test": "vitest",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5",
    "eslint": "^8.57.0",
    "prettier": "^3.3.0",
    "vitest": "^1.6.0",
    "playwright": "^1.44.1",
    "@types/node": "^20.12.12",
    "tsx": "^4.11.0",
    "tsup": "^8.1.0"
  }
}