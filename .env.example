# =============================================================================
# CometLMS — Environment Variables
# Copy to .env and fill in your values before running docker compose up
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=cometlms
POSTGRES_USER=cometlms
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# --- JWT (generate with: openssl rand -base64 48) ---
JWT_SECRET=CHANGE_ME_jwt_secret
JWT_REFRESH_SECRET=CHANGE_ME_jwt_refresh_secret

# --- AI (Groq) ---
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Frontend URL (set to your EC2 public IP or domain) ---
# Used by the API for CORS allow-origin
CLIENT_URL=http://YOUR_EC2_PUBLIC_IP
WEB_URL=http://YOUR_EC2_PUBLIC_IP
FRONTEND_URL=http://YOUR_EC2_PUBLIC_IP

# --- Vite build-time variable ---
# The frontend calls this URL for API requests.
# Since Nginx proxies /api → api:3000, this should be relative or absolute to the public host.
# Use empty string or /api for the Nginx proxy path (recommended).
VITE_API_URL=

# --- Sentry (optional) ---
SENTRY_DSN=
