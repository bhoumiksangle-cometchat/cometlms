# =============================================================================
# CometchaT — Parallel stack env (drives the SAME docker-compose.yml)
# Copy to .env.cometchat, fill in values, then deploy with:
#
#   docker compose -p cometchat --env-file .env.cometchat up -d --build
#
# Runs alongside the live CometLMS stack without touching it:
#   • -p cometchat        → isolated network (cometchat_internal) + volumes
#   • STACK_PREFIX        → container names cometchat-postgres/redis/api/web
#   • WEB_PORT / API_PORT → non-conflicting host ports
# =============================================================================

# --- Stack isolation (parallel deploy) ---
STACK_PREFIX=cometchat
WEB_PORT=8081
# Host-bind the API to localhost on a free port (container still listens on 3000)
API_PORT=127.0.0.1:3001

# --- PostgreSQL (separate CometchaT database) ---
POSTGRES_DB=cometchat
POSTGRES_USER=cometchat
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# --- JWT (generate with: openssl rand -base64 48) ---
JWT_SECRET=CHANGE_ME_jwt_secret
JWT_REFRESH_SECRET=CHANGE_ME_jwt_refresh_secret

# --- AI (Groq) ---
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Frontend URL (server IP or domain with port 8081) — used for CORS ---
CLIENT_URL=http://YOUR_SERVER_IP:8081
WEB_URL=http://YOUR_SERVER_IP:8081
FRONTEND_URL=http://YOUR_SERVER_IP:8081

# --- Vite build-time API URL (empty → nginx proxies /api → api:3000) ---
VITE_API_URL=

# --- CometChat (REQUIRED — real-time messaging) ---
# Server-side (API)
COMETCHAT_APP_ID=
COMETCHAT_REGION=
COMETCHAT_AUTH_KEY=
COMETCHAT_REST_API_KEY=
COMETCHAT_WEBHOOK_SECRET=
# Client-side credentials are baked into the bundle from COMETCHAT_APP_ID /
# COMETCHAT_REGION / COMETCHAT_AUTH_KEY above (see docker-compose.yml web args).

# --- Firebase (optional — push notifications) ---
# Admin SDK (API)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Web SDK (frontend build args)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# --- Sentry (optional) ---
SENTRY_DSN=
